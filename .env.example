# Configurações do Administrador (Seed inicial)
ADMIN_EMAIL=admin@exemplo.com.br
ADMIN_PASSWORD=SuaSenhaForteAqui
ADMIN_NAME=NomeDoAdmin

# Informações de Contato da Clínica
EMAIL_ADDRESS=contato@exemplo.com.br
CONTACT_PHONE=(00) 00000-0000

# Chave de Criptografia (32 caracteres recomendados)
ENCRYPTION_KEY=sua_chave_de_criptografia_com_32_chars

# Configurações do Resend (E-mail)
RESEND_API_KEY=re_sua_chave_aqui
RESEND_SENDER_EMAIL=sistema@seu_dominio.com.br

# Token do Cloudflare Tunnel (se aplicável ao deployment)
TUNNEL_TOKEN=seu_token_aqui

# Configurações do Banco de Dados (PostgreSQL)
DB_PASSWORD=senha_do_seu_banco
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=senha_do_seu_banco
