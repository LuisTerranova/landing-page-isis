@page "/"
@using landing_page_isis.Components.Forms
@using landing_page_isis.Components.Layout
@layout MainLayout

<div id="hero" class="d-flex align-center justify-center" style="min-height: 100vh; width: 100%;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudPaper Elevation="0" Class="bg-transparent">
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12" md="10" Class="d-flex flex-column align-center text-center">
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Style="letter-spacing: 4px; font-weight: 300;"
                             Class="mb-4">
                        AQUI É O SEU ESPACO
                    </MudText>

                    <MudText Typo="Typo.h1" Color="Color.Secondary" Style="font-weight: 900; line-height: 1.1;"
                             Class="mb-8 hero-title">
                        Sua saúde em boas mãos
                    </MudText>

                    <MudText Typo="Typo.h5" Align="Align.Center"
                             Style="font-weight: 300; line-height: 1.6; color: #555; max-width: 750px;" Class="mb-12">
                        Investir em psicoterapia é investir em uma vida mais leve e consciente. Vamos juntos construir um espaço de desenvolvimento e reflexão?
                    </MudText>

                    <div class="d-flex flex-column align-center">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 400; color: #666;">
                            Agende sua consulta
                            agora mesmo
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Style="background-color: #284B32; color: white; padding: 18px 48px; font-size: 1.1rem;"
                                   Size="Size.Large" Class="rounded-lg shadow-xl"
                                   Href="#contato">
                            Iniciar Atendimento
                        </MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
</div>

<div id="separator" class="d-flex justify-center">
    <MudImage Src="isis-content-separator.png" Height="120" Alt="Separador Isis Vitória"/>
</div>

<div id="sobre" class="d-flex align-center justify-center" style="min-height: 100vh; width: 100%;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudPaper Elevation="0" Class="bg-transparent">
            <MudGrid Spacing="10">
                <MudItem xs="12" md="7" Class="d-flex flex-column justify-center align-center align-md-start text-center text-md-start pe-md-12">
                    <MudText Typo="Typo.h6" Color="Color.Secondary"
                             Style="letter-spacing: 2px; font-weight: 300; margin-bottom: 10px">
                        CONHEÇA MINHA TRAJETÓRIA
                    </MudText>
                    <MudText Typo="Typo.h2" Color="Color.Secondary" Class="mb-4" Style="font-weight: 700;">
                        Sobre Mim
                    </MudText>

                    <div style="width: 60px; height: 4px; background-color: #284B32; border-radius: 2px;"
                         class="mb-8 mx-auto mx-md-0">
                    </div>

                    <MudText Typo="Typo.h6" Class="mb-6" Align="Align.Justify"
                             Style="font-weight: 400; line-height: 1.8; color: #444; font-size: 1.2rem;">
                        O desenvolvimento humano é um processo contínuo e profudandmente interligado com as interações sociais e cultura em que o indivíduo está inserido.
                        Pautada na <b>Psicologia Histórico-cultural</b> busco compreender o ser humano a partir de sua história de vida e das mediações que moldam sua subjetividade e personalidade.
                    </MudText>

                    <MudStack Row="true" Spacing="3" Class="mt-4 flex-wrap justify-center justify-md-start">
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Ética
                        </MudChip>
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Acolhimento
                        </MudChip>
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Ciência
                        </MudChip>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="5" Class="isis-photo photo-bg rounded-xl d-flex align-end justify-center pa-0">
                    <MudImage Src="isis-photo.png" Alt="Isis Vitória" Class="rounded-xl isis-photo" Fluid="true"/>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
</div>


<div id="servicos" class="d-flex align-center justify-center"
     style="min-height: 100vh; width: 100%; background-color: #284B32; padding: 60px 0;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <div class="d-flex flex-column align-center text-center mb-12">
            <MudText Typo="Typo.h6" Style="letter-spacing: 3px; color: rgba(255,255,255,0.7); font-weight: 300;">
                COMO
                POSSO AJUDAR
            </MudText>
            <MudText Typo="Typo.h2" Style="color: white; font-weight: 800; line-height: 1.1;">Meus Serviços</MudText>
            <div style="width: 80px; height: 4px; background-color: #7E0F20; border-radius: 2px;" class="mt-4"></div>
        </div>

        <MudGrid Spacing="6" Justify="Justify.Center">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-10 rounded-xl d-flex flex-column align-center text-center"
                          Style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.SelfImprovement" Style="color: white;" Size="Size.Large"
                             Class="mb-4"/>
                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 700;" Class="mb-4">
                        Psicoterapia
                        Individual
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); line-height: 1.7;">
                        Um espaço seguro, sigiloso, criado a partir do afeto para explorar e entender sua subjetividade e resignificar sua história a partir da abordagem Histórico-cultural.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-10 rounded-xl d-flex flex-column align-center text-center"
                          Style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: white;" Size="Size.Large"
                             Class="mb-4"/>
                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 700;" Class="mb-4">
                        Psicoterapia de Casal
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); line-height: 1.7;">
                        Um espaço intermediado para gerar conexão, resolver conflitos, e juntos aprender ferramentas para uma comunicação, e relação mais assertiva.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</div>


<div id="contato">
    <LeadFormContact/>
</div>

