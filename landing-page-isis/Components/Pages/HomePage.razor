@page "/"
@using landing_page_isis.Components.Forms
@using landing_page_isis.Components.Layout
@layout MainLayout
@inject IJSRuntime Js

<PageTitle>Psicóloga Isis Vitória | Psicoterapia e Atendimento Online</PageTitle>

<HeadContent>
    <meta name="description" content="Psicóloga Isis Vitória - Psicoterapia e Atendimento Psicológico 100% Online (Remoto) para todo o Brasil e brasileiros no exterior. Abordagem Histórico-cultural." />
    <meta name="keywords" content="psicóloga porto velho, psicóloga isis vitória, psicoterapia porto velho, psicologia histórico-cultural, psicoterapia online, atendimento online, terapia online, psicóloga online, psicoterapia individual, psicoterapia de casal, atendimento remoto" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href="https://psi.isisvitoria.com.br/" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Psicóloga Isis Vitória | Psicoterapia e Atendimento Online" />
    <meta property="og:description" content="Atendimento Psicológico 100% Online (Remoto) para todo o Brasil e brasileiros no exterior. Vamos juntos construir um espaço de desenvolvimento e reflexão?" />
    <meta property="og:image" content="https://psi.isisvitoria.com.br/isis-photo.png" />
    <meta property="og:url" content="https://psi.isisvitoria.com.br/" />
    <meta property="og:site_name" content="Psicóloga Isis Vitória" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Psicóloga Isis Vitória | Psicoterapia e Atendimento Online" />
    <meta name="twitter:description" content="Atendimento Psicológico 100% Online (Remoto) para todo o Brasil e brasileiros no exterior. Vamos juntos construir um espaço de desenvolvimento e reflexão?" />
    <meta name="twitter:image" content="https://psi.isisvitoria.com.br/isis-photo.png" />
    
    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "Psychologist",
          "name": "Psicóloga Isis Vitória",
          "image": "https://psi.isisvitoria.com.br/isis-photo.png",
          "description": "Psicoterapia individual e de casal sob a abordagem da Psicologia Histórico-cultural. Atendimento 100% online (remoto) para pacientes em todo o Brasil e exterior.",
          "address": {
            "@@type": "PostalAddress",
            "addressLocality": "Porto Velho",
            "addressRegion": "RO",
            "addressCountry": "BR"
          },
          "url": "https://psi.isisvitoria.com.br/",
          "telephone": "@(Environment.GetEnvironmentVariable("CONTACT_PHONE") ?? "")",
          "priceRange": "$$",
          "knowsAbout": ["Psicologia Histórico-cultural", "Psicoterapia Individual", "Psicoterapia de Casal", "Desenvolvimento Humano"],
          "offers": {
            "@@type": "Offer",
            "name": "Atendimento Psicológico Online",
            "description": "Sessões de psicoterapia individual e de casal realizadas de forma 100% online por videochamada para pacientes em todo o Brasil e no exterior.",
            "category": "Mental Health Services"
          },
          "sameAs": [
            "https://www.instagram.com/psicologaisisvitoria"
          ]
        }
    </script>

    <!-- FAQ Structured Data (JSON-LD) -->
    <script type="application/ld+json">
        {
          "@@context": "https://schema.org",
          "@@type": "FAQPage",
          "mainEntity": [
            {
              "@@type": "Question",
              "name": "Como funciona a psicoterapia online?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "As consultas são realizadas por videochamada em um ambiente seguro, sigiloso e em conformidade com as normas do Conselho Federal de Psicologia. Você só precisa de um dispositivo com acesso à internet e um local reservado que garanta sua privacidade durante a sessão."
              }
            },
            {
              "@@type": "Question",
              "name": "O atendimento online é tão eficaz quanto o presencial?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Sim. Diversos estudos científicos e o próprio Conselho Federal de Psicologia (CFP) reconhecem a mesma eficácia clínica para o modelo online. A modalidade proporciona maior flexibilidade, elimina barreiras geográficas e economiza tempo de deslocamento, mantendo o acolhimento e o rigor científico."
              }
            },
            {
              "@@type": "Question",
              "name": "Quem pode realizar psicoterapia online?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Qualquer pessoa (jovens, adultos e casais) em busca de autoconhecimento ou lidando com questões como ansiedade, estresse, transições de vida, angústias cotidianas e conflitos de relacionamento."
              }
            },
            {
              "@@type": "Question",
              "name": "Como é feito o agendamento?",
              "acceptedAnswer": {
                "@@type": "Answer",
                "text": "Basta preencher o formulário de contato abaixo ou clicar no botão flutuante do WhatsApp para conversarmos. Vamos alinhar suas necessidades e definir o melhor dia e horário para as sessões."
              }
            }
          ]
        }
    </script>
</HeadContent>

<div id="hero" class="d-flex align-center justify-center" style="min-height: 100vh; width: 100%;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudPaper Elevation="0" Class="bg-transparent">
            <MudGrid Justify="Justify.Center">
                <MudItem xs="12" md="10" Class="d-flex flex-column align-center text-center">
                    <MudText Typo="Typo.h6" Color="Color.Secondary" Style="letter-spacing: 4px; font-weight: 300;"
                             Class="mb-4">
                        AQUI É O SEU ESPACO
                    </MudText>

                    <MudText Typo="Typo.h1" Color="Color.Secondary" Style="font-weight: 900; line-height: 1.1;"
                             Class="mb-8 hero-title">
                        Sua saúde em boas mãos
                    </MudText>

                    <MudText Typo="Typo.h5" Align="Align.Center"
                             Style="font-weight: 300; line-height: 1.6; color: #555; max-width: 750px;" Class="mb-8">
                        Investir em psicoterapia é investir em uma vida mais leve e consciente. Vamos juntos construir um espaço de desenvolvimento e reflexão?
                    </MudText>

                    <div style="width: 65px; height: 3px; background-color: #7E0F20; border-radius: 2px;"
                         class="mb-8 mx-auto">
                    </div>

                    <MudText Typo="Typo.h6" Align="Align.Center"
                             Style="font-weight: 400; line-height: 1.6; color: #666; max-width: 750px;" Class="mb-12">
                        Ofereço atendimento psicológico 100% online (remoto) para todo o Brasil e brasileiros no exterior.
                    </MudText>

                    <div class="d-flex flex-column align-center">
                        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight: 400; color: #666;">
                            Agende sua consulta
                            agora mesmo
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Style="background-color: #284B32; color: white; padding: 18px 48px; font-size: 1.1rem;"
                                   Size="Size.Large" Class="rounded-lg shadow-xl"
                                   Href="#contato">
                            Iniciar Atendimento
                        </MudButton>
                    </div>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
</div>

<div id="separator" class="d-flex justify-center">
    <MudImage Src="isis-content-separator.png" Height="120" Alt="Separador Isis Vitória"/>
</div>

<div id="sobre" class="d-flex align-center justify-center" style="min-height: 100vh; width: 100%;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudPaper Elevation="0" Class="bg-transparent">
            <MudGrid Spacing="6" AlignItems="AlignItems.Center">
                <MudItem xs="12" md="7" Class="d-flex flex-column justify-center align-center align-md-start text-center text-md-start pe-md-12">
                    <MudText Typo="Typo.h6" Color="Color.Secondary"
                             Style="letter-spacing: 2px; font-weight: 300; margin-bottom: 10px">
                        CONHEÇA MINHA TRAJETÓRIA
                    </MudText>
                    <MudText Typo="Typo.h2" Color="Color.Secondary" Class="mb-4" Style="font-weight: 700;">
                        Sobre Mim
                    </MudText>

                    <div style="width: 60px; height: 4px; background-color: #284B32; border-radius: 2px;"
                         class="mb-8 mx-auto mx-md-0">
                    </div>

                    <MudText Typo="Typo.h6" Class="mb-6" Align="Align.Justify"
                             Style="font-weight: 400; line-height: 1.8; color: #444; font-size: 1.2rem;">
                        O desenvolvimento humano é um processo contínuo e profundamente interligado com as interações sociais e a cultura em que o indivíduo está inserido.
                        Como psicóloga com base em Porto Velho - RO e realizando atendimento 100% online (remoto), pauto meu trabalho na <b>Psicologia Histórico-cultural</b> para compreender o ser humano a partir de sua história de vida e das mediações que moldam sua subjetividade e personalidade.
                    </MudText>

                    <MudStack Row="true" Spacing="3" Class="mt-4 flex-wrap justify-center justify-md-start">
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Ética
                        </MudChip>
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Acolhimento
                        </MudChip>
                        <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Secondary"
                                 Variant="Variant.Text" Style="font-weight: 500;">
                            Ciência
                        </MudChip>
                    </MudStack>
                </MudItem>

                <MudItem xs="12" md="5" Class="photo-bg rounded-xl d-flex align-end justify-center pa-0 mt-8 mt-md-0">
                    <MudImage Src="isis-photo.png" Alt="Isis Vitória" Class="isis-photo" Fluid="true"/>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </MudContainer>
</div>


<div id="servicos" class="d-flex align-center justify-center"
     style="min-height: 100vh; width: 100%; background-color: #284B32; padding: 60px 0;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <div class="d-flex flex-column align-center text-center mb-12">
            <MudText Typo="Typo.h6" Style="letter-spacing: 3px; color: rgba(255,255,255,0.7); font-weight: 300;">
                COMO
                POSSO AJUDAR
            </MudText>
            <MudText Typo="Typo.h2" Style="color: white; font-weight: 800; line-height: 1.1;">Meus Serviços</MudText>
            <div style="width: 80px; height: 4px; background-color: #7E0F20; border-radius: 2px;" class="mt-4"></div>
        </div>

        <MudGrid Spacing="6" Justify="Justify.Center">
            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-6 pa-md-10 rounded-xl d-flex flex-column align-center text-center"
                          Style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.SelfImprovement" Style="color: white;" Size="Size.Large"
                             Class="mb-4"/>
                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 700;" Class="mb-4">
                        Psicoterapia
                        Individual
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); line-height: 1.7;">
                        Um espaço seguro, sigiloso, criado a partir do afeto para explorar e entender sua subjetividade e ressignificar sua história a partir da abordagem Histórico-cultural.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-6 pa-md-10 rounded-xl d-flex flex-column align-center text-center"
                          Style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.LaptopMac" Style="color: white;" Size="Size.Large"
                             Class="mb-4"/>
                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 700;" Class="mb-4">
                        Atendimento
                        Online
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); line-height: 1.7;">
                        Consultas remotas de psicoterapia por videochamada com o mesmo sigilo e eficácia. Flexibilidade de horários e comodidade para ser atendido de onde estiver.
                    </MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Elevation="0" Class="pa-6 pa-md-10 rounded-xl d-flex flex-column align-center text-center"
                          Style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); height: 100%;">
                    <MudIcon Icon="@Icons.Material.Filled.Groups" Style="color: white;" Size="Size.Large"
                             Class="mb-4"/>
                    <MudText Typo="Typo.h5" Style="color: white; font-weight: 700;" Class="mb-4">
                        Psicoterapia de Casal
                    </MudText>
                    <MudText Typo="Typo.body1" Align="Align.Center" Style="color: rgba(255,255,255,0.8); line-height: 1.7;">
                        Um espaço intermediado para gerar conexão, resolver conflitos, e juntos aprender ferramentas para uma comunicação e relação mais assertiva.
                    </MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</div>

<FaqSection />

<div id="contato">
    <LeadFormContact/>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Removes automatic visual focus
            await Js.InvokeVoidAsync("eval", "document.activeElement?.blur()");
        }
    }
}
