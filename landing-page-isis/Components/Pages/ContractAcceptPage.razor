@page "/contrato/{Token}"
@using landing_page_isis.Components.Layout
@layout ContractAcceptLayout
@using landing_page_isis.core
@using landing_page_isis.core.Models
@using landing_page_isis.Components.Helpers
@using RazorLight

@rendermode InteractiveServer
@inject IContractHandler ContractHandler
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject RazorLightEngine RazorLight
@inject IJSRuntime Js
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8" Style="min-height: 75vh;">
    @if (_loading)
    {
        <MudStack Row="false" AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 50vh;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true"
                                 Size="Size.Large" Class="mb-4" />
            <MudText Typo="Typo.body1">Carregando contrato...</MudText>
        </MudStack>
    }
    else if (_contract == null)
    {
        <MudPaper Elevation="4" Class="pa-10 text-center" Style="border-radius: 24px;">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h5" Color="Color.Error" Class="mt-4">Link inválido</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">O link que você acessou não é válido ou já expirou.</MudText>
        </MudPaper>
    }
    else if (_contract.Status == ContractStatus.Ativo)
    {
        <SuccessRedirect Title="Contrato já aceito"
                         Message="@_successMessage" />
    }
    else if (_contract.Status == ContractStatus.Cancelado)
    {
        <MudPaper Elevation="4" Class="pa-10 text-center" Style="border-radius: 24px;">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Large" />
            <MudText Typo="Typo.h5" Color="Color.Error" Class="mt-4">Contrato cancelado</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">Este contrato foi cancelado. Entre em contato pelo WhatsApp (69) 99223-4931.</MudText>
        </MudPaper>
    }
    else if (_expired)
    {
        <MudPaper Elevation="4" Class="pa-10 text-center" Style="border-radius: 24px;">
            <MudIcon Icon="@Icons.Material.Filled.TimerOff" Color="Color.Warning" Size="Size.Large" />
            <MudText Typo="Typo.h5" Color="Color.Warning" Class="mt-4">Link expirado</MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                O link de aceitação expirou (válido por 2 dias). Entre em contato pelo WhatsApp (69) 99223-4931 para reenviarmos.
            </MudText>
        </MudPaper>
    }
    else if (_contract.Status == ContractStatus.AguardandoAceitacao && !_cpfVerified)
    {
        @* Challenge the patient for the last 3 digits of their CPF to protect sensitive contract contents before display *@
        <MudPaper Elevation="4" Class="pa-10 text-center" Style="border-radius: 24px; max-width: 500px; margin: 0 auto;">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Primary" Size="Size.Large" />
            <MudText Typo="Typo.h5" Style="color: #284B32; font-weight: 700;" Class="mt-4">Confirme sua identidade</MudText>
            <MudText Typo="Typo.body1" Class="mt-4 mb-6">
                Para sua segurança, confirme os <strong>3 últimos dígitos</strong> do CPF cadastrado.
            </MudText>
 
<MudStack Row="false" AlignItems="AlignItems.Center" Style="gap: 8px;">
                <MudText Typo="Typo.body2">
                    CPF: <strong>XXX.XXX.XXX-</strong>
                </MudText>

                <MudTextField T="string"
                              Variant="Variant.Outlined"
                              Label="Últimos 3 dígitos"
                              @bind-Value="_cpfInput"
                              MaxLength="3"
                              Style="width: 160px;"
                              Error="@(!string.IsNullOrEmpty(_cpfError))"
                              ErrorText="@_cpfError" />

                <MudButton Variant="Variant.Filled"
                           Style="background-color: #284B32; color: white; font-weight: 700; border-radius: 12px; height: 48px; width: 160px;"
                           OnClick="ConfirmCpf">
                    Confirmar
                </MudButton>
            </MudStack>
        </MudPaper>
    }
    else if (_contract.Status == ContractStatus.AguardandoAceitacao)
    {
        <MudText Typo="Typo.h3" Style="color: #284B32; font-weight: 700;" Class="mb-1 text-center">
            Revisão do Contrato
        </MudText>
        <MudText Typo="Typo.body1" Style="color: #7E0F20;" Class="mb-4 text-center">
            Por favor, leia o contrato abaixo até o final para habilitar a aceitação.
        </MudText>
 
        <MudPaper Elevation="4" Style="border-radius: 24px; overflow: hidden;">
            <div @ref="_contractDiv"
                 id="contract-content"
                 style="height: 55vh; overflow-y: auto; padding: 24px; background: white;">
                @((MarkupString)(_contract.ContractDocumentHtml ?? ""))
            </div>
        </MudPaper>
 
<MudStack Row="false" AlignItems="AlignItems.Center" Spacing="1" Class="mt-4">
            <MudAlert Severity="@(_hasScrolledToBottom ? Severity.Success : Severity.Warning)"
                      Class="mb-2" Style="max-width: 500px;">
                @if (_hasScrolledToBottom)
                {
                    <MudText Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-1" Size="Size.Small" />
                        Você já leu o contrato completo.
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2">
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Class="mr-1" Size="Size.Small" />
                        Role até o final do contrato para habilitar a aceitação.
                    </MudText>
                }
            </MudAlert>

            <MudButton Variant="Variant.Filled"
                       Style="background-color: #284B32; color: white; height: 56px; font-weight: 700; font-size: 1.1rem; border-radius: 12px; padding: 0 48px;"
                       OnClick="ShowAcceptConfirmation"
                       Disabled="@(!_hasScrolledToBottom || _accepting)">
                @if (_accepting)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Processando...</MudText>
                }
                else
                {
                    <MudText>ACEITAR CONTRATO</MudText>
                }
            </MudButton>
        </MudStack>
    }
</MudContainer>
 
@code {
    [Parameter] public string Token { get; set; } = string.Empty;
 
    private Contract? _contract;
    private bool _loading = true;
    private bool _expired;
    private bool _accepting;
    private bool _hasScrolledToBottom;
    private string _successMessage = string.Empty;
 
private bool _cpfVerified;
    private string _cpfInput = string.Empty;
    private string _cpfError = string.Empty;

    private ElementReference _contractDiv;
    private bool _scrollMonitorAttached;
    private DotNetObjectReference<ContractAcceptPage>? _dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        _contract = await ContractHandler.GetContractByToken(Token);

        if (_contract is { Status: ContractStatus.AguardandoAceitacao }
            && (_contract.TokenGeneratedAt ?? _contract.CreatedAt).AddDays(2) < DateTimeOffset.UtcNow)
        {
            _expired = true;
        }

        if (_contract is { Status: ContractStatus.Ativo })
        {
            _successMessage = $"Este contrato foi aceito em {_contract.AcceptedAt?.ToOffset(TimeSpan.FromHours(-3)).ToString("dd/MM/yyyy 'às' HH:mm")}.";
        }

        _loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_scrollMonitorAttached
            && _contract is { Status: ContractStatus.AguardandoAceitacao }
            && _cpfVerified)
        {
            _scrollMonitorAttached = true;
            await Task.Delay(200);
            _dotNetRef = DotNetObjectReference.Create(this);
            await Js.InvokeVoidAsync("monitorContractScroll", _contractDiv, _dotNetRef);
        }
    }

    [JSInvokable]
    public Task OnScrolledToBottom()
    {
        _hasScrolledToBottom = true;
        StateHasChanged();
        return Task.CompletedTask;
    }
 
public void Dispose()
    {
        _dotNetRef?.Dispose();
    }
 
    private async Task ConfirmCpf()
    {
        _cpfError = string.Empty;
 
        if (_contract == null)
            return;
 
        var valid = await ContractHandler.VerifyCpfDigits(_contract.Id, _cpfInput);
 
        if (!valid)
        {
            _cpfError = "Os dígitos não conferem. Tente novamente.";
            return;
        }
 
        _cpfVerified = true;
    }
 
    private async Task ShowAcceptConfirmation()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            BackdropClick = false,
            CloseButton = true,
        };
 
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Confirmar Aceitação",
            "Tem certeza que deseja aceitar este contrato? Esta ação é irreversível.",
            yesText: "Sim, aceitar contrato",
            cancelText: "Cancelar",
            options: options
        );
 
        if (confirmed == true)
        {
            await AcceptContract();
        }
    }
 
private async Task AcceptContract()
    {
        _accepting = true;
        try
        {
            if (_contract == null)
                return;

            var renderContract = _contract;

            // If couple contract, fetch full couple record (with both partner names) to render the HTML template properly
            if (_contract.CoupleId.HasValue)
            {
                renderContract = await ContractHandler.GetContractByCoupleId(_contract.CoupleId.Value);
            }

            renderContract ??= _contract;
            renderContract.AcceptedAt = DateTimeOffset.UtcNow;
            var html = await RazorLight.CompileRenderAsync("ContractTemplate.cshtml", renderContract);

            var result = await ContractHandler.AcceptContract(Token, html);
            if (result.Success)
            {
                _contract.Status = ContractStatus.Ativo;
                _contract.AcceptedAt = renderContract.AcceptedAt;
_contract.ContractDocumentHtml = html;

                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Erro: {result.Message}", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Ocorreu um erro inesperado ao processar a aceitação.", Severity.Error);
        }
        finally
        {
            _accepting = false;
        }
    }
}
