@page "/admin/financeiro"
@attribute [Authorize]
@using landing_page_isis.Components.Layout
@layout DashboardLayout
@rendermode InteractiveServer

<MudText Typo="Typo.h4" Class="mb-6" Color="Color.Secondary" Style="font-weight: 800">
    FINANCEIRO
</MudText>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
}
else
{
    <MudGrid>
        <!-- KPI Cards -->
        <MudItem xs="12" sm="4">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Atual (R$)
                    </MudText>
                    <MudText Typo="Typo.h4" Class="white-text" Style="font-weight: 700;">
                        @_currentRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Mensal Prevista (R$)
                    </MudText>
                    <MudText Typo="Typo.h4" Class="white-text" Style="font-weight: 700;">
                        @_expectedMonthlyRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="4">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Anual Total (R$)
                    </MudText>
                    <MudText Typo="Typo.h4" Class="white-text" Style="font-weight: 700;">
                        @_annualRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Charts -->
        <MudItem xs="12" md="8">
            <MudCard Class="mud-theme-secondary hover-elevate transition-all" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="white-text">Desempenho Anual</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_monthlyRevenueSeries" XAxisLabels="@_monthlyRevenueLabels" Width="100%" Height="350px"/>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Class="mud-theme-secondary hover-elevate transition-all" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="white-text">Status de Agendamentos</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="d-flex justify-center">
                    <MudChart T="double" ChartType="ChartType.Donut" InputData="@_statusChartData" InputLabels="@_statusChartLabels" Width="100%" Height="350px"/>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}