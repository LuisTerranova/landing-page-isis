@page "/admin/financeiro"
@attribute [Authorize]
@using landing_page_isis.Components.Layout
@layout DashboardLayout
@rendermode InteractiveServer

<PageTitle>Financeiro | Isis Vitória</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <MudText Typo="Typo.h4" Color="Color.Secondary" Style="font-weight: 800">
        FINANCEIRO
    </MudText>

    <MudPaper Class="pa-2 d-flex align-center gap-2" Elevation="1" Style="background-color: var(--mud-palette-surface);">
        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="Color.Primary" OnClick="PreviousMonth" />
        <MudText Typo="Typo.subtitle1" Style="min-width: 200px; text-align: center; font-weight: 600;">
            @_rangeLabel
        </MudText>
        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Primary" OnClick="NextMonth" />
        <MudDatePicker Label="De" @bind-Date="_startDate"
                        Margin="Margin.Dense" Variant="Variant.Outlined"
                        DateFormat="dd/MM/yyyy" />
        <MudDatePicker Label="Até" @bind-Date="_endDate"
                        Margin="Margin.Dense" Variant="Variant.Outlined"
                        DateFormat="dd/MM/yyyy" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="LoadFinances" StartIcon="@Icons.Material.Filled.Search">
            Filtrar
        </MudButton>
    </MudPaper>
</div>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
}
else
{
    <MudGrid>
        <!-- KPI Cards -->
        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Realizada (R$)
                    </MudText>
                    <MudText Typo="Typo.h5" Class="white-text" Style="font-weight: 700;">
                        @_realizedRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Pendente (R$)
                    </MudText>
                    <MudText Typo="Typo.h5" Class="white-text" Style="font-weight: 700;">
                        @_pendingRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita Total Prevista (R$)
                    </MudText>
                    <MudText Typo="Typo.h5" Class="white-text" Style="font-weight: 700;">
                        @_totalRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" sm="6" lg="3">
            <MudCard Class="schedule-card hover-elevate transition-all">
                <MudCardContent>
                    <MudText Typo="Typo.subtitle2" Class="white-text-70 uppercase mb-2">
                        Receita de Pacotes (R$)
                    </MudText>
                    <MudText Typo="Typo.h5" Class="white-text" Style="font-weight: 700;">
                        @_packagesRevenue.ToString("C")
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Charts -->
        <MudItem xs="12">
            <MudCard Class="mud-theme-secondary hover-elevate transition-all">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="white-text">Desempenho de Receita Mensal (Consultas + Pacotes)</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_monthlyRevenueSeries" xaxislabels="@_monthlyRevenueLabels" Width="100%" Height="350px"/>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}