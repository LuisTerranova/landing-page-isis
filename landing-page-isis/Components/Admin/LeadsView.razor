@page "/admin/leads"
@attribute [Authorize]
@using landing_page_isis.Components.Layout
@using landing_page_isis.core.Models
@layout DashboardLayout
@rendermode InteractiveServer

<AdminShell>
    <MudText Typo="Typo.h4" Class="mb-6" Color="Color.Secondary" Style="font-weight: 800">
        LEADS
    </MudText>

    <GenericTable @ref="_leadsTable"
                  TItem="Lead"
                  EditText="Aprovar"
                  ShowCreateButton="@false"
                  ServerData="@ServerReload"
                  OnEdit="@(ApproveLead)"
                  OnDelete="@(DeleteLead)">

        <CustomActions>
            <MudMenuItem OnClick="@(() => ViewIntent(context))">
                <MudIcon Icon="@Icons.Material.Filled.Info" Class="me-2"/> Ver Intenção
            </MudMenuItem>
        </CustomActions>

        <HeaderColumns>
            <MudTh>Nome</MudTh>
            <MudTh>Telefone</MudTh>
            <MudTh>Criado em</MudTh>
            <MudTh>Status</MudTh>
        </HeaderColumns>

        <RowColumns>
            <MudTd DataLabel="Nome">@context.Name</MudTd>
            <MudTd DataLabel="Telefone">@context.Phone.FormatPhone()</MudTd>
            <MudTd DataLabel="Criado em">@context.Created</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Variant="Variant.Filled" Size="Size.Small" Class="@($"status-{context.LeadStatus.ToString().ToLower()}")">
                    @context.LeadStatus.ToString().ToUpper()
                </MudChip>
            </MudTd>
        </RowColumns>

    </GenericTable>
</AdminShell>