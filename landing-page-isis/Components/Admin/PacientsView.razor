@page "/admin/pacientes"
@attribute [Authorize]
@using landing_page_isis.Components.Layout
@using landing_page_isis.core.Models
@layout DashboardLayout
@rendermode InteractiveServer


    <MudText Typo="Typo.h4" Class="mb-6" Color="Color.Secondary" Style="font-weight: 800">
        PACIENTES
    </MudText>

    <GenericTable @ref="_pacientsTable"
                  TItem="Pacient"
                  ServerData="@ServerReload"
                  OnCreate="@(OpenCreate)"
                  OnEdit="@(EditPacient)"
                  OnDelete="@(DeletePacient)">

        <HeaderColumns>
            <MudTh>Nome</MudTh>
            <MudTh>E-mail</MudTh>
            <MudTh>Telefone</MudTh>
            <MudTh>Estado</MudTh>
        </HeaderColumns>

        <RowColumns>
            <MudTd DataLabel="Nome">@context.Name</MudTd>
            <MudTd DataLabel="E-mail">@context.Email</MudTd>
            <MudTd DataLabel="Telefone">@context.Phone.FormatPhone()</MudTd>
            <MudTd DataLabel="Estado">@context.StateOfResidency</MudTd>
        </RowColumns>

        <CustomActions>

        </CustomActions>
    </GenericTable>

