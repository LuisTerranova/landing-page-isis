    // ==================== TAB HANDLING ====================

    private async Task OnTabChanged(int index)
    {
        if (index == 1 && !_recordsLoaded)
        {
            await LoadRecordsAsync();
        }
        else if (index == 2 && !_contractLoaded)
        {
            await LoadContractAsync();
        }
        else if (index == 3 && !_packagesLoaded)
        {
            await LoadPackagesAsync();
        }
    }

    // ==================== RECORDS ====================

    private async Task OnFilterDateChanged(DateTime? newDate)
    {
        _recordsFilterDate = newDate;
        _records.Clear();
        _recordPage = 0;
        await LoadRecordsAsync();
    }

    private async Task LoadRecordsAsync()
    {
        _isLoadingRecords = true;
        StateHasChanged();

        if (IsCouple)
        {
            var coupleId = Couple!.Id;
            var appointments = await AppointmentHandler.GetAppointmentsByCoupleId(coupleId, CancellationToken.None);
            foreach (var app in appointments)
            {
                var record = await RecordHandler.GetAppointmentRecordByAppointmentId(app.Id);
                if (record != null)
                {
                    _records.Add(new AppointmentRecordListItemDto(
                        record.Id,
                        record.AppointmentId,
                        app.AppointmentDate,
                        record.Note ?? string.Empty,
                        record.CreatedAt,
                        record.UpdatedAt
                    ));
                }
            }
            _totalRecords = _records.Count;
            _recordsLoaded = true;
        }
        else
        {
            var result = await RecordHandler.GetRecordsByPatientId(
                _recordPage,
                RecordsPageSize,
                Patient!.Id,
                _recordsFilterDate,
                CancellationToken.None
            );
            _records.AddRange(result.Items);
            _totalRecords = result.TotalItems;
            _recordsLoaded = true;
        }

        _isLoadingRecords = false;
    }

    private async Task LoadMoreRecords()
    {
        _recordPage++;
        await LoadRecordsAsync();
    }

    // ==================== PACKAGES ====================

    private async Task LoadPackagesAsync()
    {
        _isLoadingPackages = true;
        StateHasChanged();

        PaginatedResponse<AppointmentPackageListItemDto> result;

        if (IsCouple)
        {
            result = await PackageHandler.GetPackagesByCoupleId(0, 50, Couple!.Id, CancellationToken.None);
        }
        else
        {
            result = await PackageHandler.GetPackagesByPatientId(0, 50, Patient!.Id, CancellationToken.None);
        }

        _packages = result.Items.ToList();
        _packagesLoaded = true;
        _isLoadingPackages = false;
    }

    private async Task OpenCreatePackage()
    {
        Guid ownerId;
        string? payerName;
        string? payerCpf;

        if (IsCouple)
        {
            ownerId = Couple!.Id;
            payerName = Couple.PayerName;
            payerCpf = Couple.PayerCpf;
        }
        else
        {
            ownerId = Patient!.Id;
            payerName = Patient.PayerName;
            payerCpf = Patient.PayerCpf;
        }

        var parameters = new DialogParameters<AppointmentPackageDialog>
        {
            {
                x => x.Model,
                new AppointmentPackage
                {
                    PayerName = payerName,
                    PayerCpf = payerCpf,
                }
            },
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = false,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<AppointmentPackageDialog>(string.Empty, parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: AppointmentPackage newPackage })
        {
            if (IsCouple)
            {
                newPackage.CoupleId = ownerId;
            }
            else
            {
                newPackage.PatientId = ownerId;
            }

            var response = await PackageHandler.CreatePackage(newPackage);
            if (response.Success)
            {
                Snackbar.Add("Pacote criado com sucesso!", Severity.Success);
                _packagesLoaded = false;
                await LoadPackagesAsync();
            }
            else
            {
                Snackbar.Add($"Erro ao criar pacote: {response.Message}", Severity.Warning);
            }
        }
    }

    private async Task OpenEditPackage(AppointmentPackageListItemDto pkg)
    {
        var parameters = new DialogParameters<AppointmentPackageDialog>
        {
            {
                x => x.Model,
                new AppointmentPackage
                {
                    Id = pkg.Id,
                    PatientId = pkg.PatientId,
                    TotalAppointments = pkg.TotalAppointments,
