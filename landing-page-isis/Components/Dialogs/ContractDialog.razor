@namespace landing_page_isis.Components.Dialogs
@using landing_page_isis.core
@using landing_page_isis.core.Models
@using landing_page_isis.Extensions
@using RazorLight
@inject ISnackbar Snackbar
@inject IContractHandler ContractHandler
@inject RazorLightEngine RazorLight

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EditNote" Class="mr-3 mb-n1" />
            Editar Contrato
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="@_formValido">
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2 mb-n1" />
                Dados do Paciente (somente leitura)
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Nome" Variant="Variant.Outlined"
                                  Value="Model.PatientName" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="CPF" Variant="Variant.Outlined"
                                  Value="Model.PatientCpf.FormatCpf()" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined"
                                  Value="Model.PatientEmail" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Telefone" Variant="Variant.Outlined"
                                  Value="Model.PatientPhone.FormatPhone()" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Estado" Variant="Variant.Outlined"
                                  Value="Model.PatientState" ReadOnly="true" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Nascimento" Variant="Variant.Outlined"
                                  Value="@(Model.PatientBirthDate?.ToString("dd/MM/yyyy") ?? "—")" ReadOnly="true" />
                </MudItem>
            </MudGrid>

            <MudDivider DividerType="DividerType.Middle" Class="my-6" />

            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2 mb-n1" />
                Detalhes do Contrato
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="4">
                    <MudNumericField T="decimal?" Label="Valor por Sessão (R$)" Variant="Variant.Outlined"
                                     @bind-Value="Model.Price" Format="F2" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="int?" Label="Sessões por Pacote" Variant="Variant.Outlined"
                                     @bind-Value="Model.InitialAppointments" />
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudNumericField T="decimal?" Label="Valor do Pacote Mensal (R$)" Variant="Variant.Outlined"
                                     @bind-Value="Model.PackagePrice" Format="F2" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="ContractType?" Label="Tipo de Contrato" Variant="Variant.Outlined"
                               @bind-Value="Model.Type">
                        <MudSelectItem T="ContractType?" Value="ContractType.Pacote">Pacote</MudSelectItem>
                        <MudSelectItem T="ContractType?" Value="ContractType.Avulso">Avulso</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudSelect T="ContractStatus" Label="Status" Variant="Variant.Outlined"
                               @bind-Value="Model.Status">
                        <MudSelectItem T="ContractStatus" Value="ContractStatus.Rascunho">Rascunho</MudSelectItem>
                        <MudSelectItem T="ContractStatus" Value="ContractStatus.AguardandoAceitacao">Aguardando Aceitação</MudSelectItem>
                        <MudSelectItem T="ContractStatus" Value="ContractStatus.Ativo">Ativo</MudSelectItem>
                        <MudSelectItem T="ContractStatus" Value="ContractStatus.Cancelado">Cancelado</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    @if (Model.Price.HasValue && Model.PackagePrice.HasValue && Model.InitialAppointments.HasValue && Model.InitialAppointments > 0)
                    {
                        <MudText Typo="Typo.body2" Color="Color.Primary" Class="mt-2">
                            Avulso: R$ @Model.Price.Value.ToString("F2") por sessão |
                            Pacote: @Model.InitialAppointments sessões por R$ @Model.PackagePrice.Value.ToString("F2")
                            (R$ @((Model.PackagePrice.Value / Model.InitialAppointments.Value).ToString("F2"))/sessão)
                        </MudText>
                    }
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Color="Color.Error">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Salvar" Disabled="@(!_formValido)">
            Salvar
        </MudButton>
        <MudButton Color="Color.Tertiary" Variant="Variant.Outlined"
                   OnClick="GerarDocumento" Disabled="_gerando">
            @if (_gerando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Gerar Documento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Contract Model { get; set; } = new();

    private bool _formValido = true;
    private bool _gerando;

    private void Cancelar() => MudDialog.Cancel();

    private async Task Salvar()
    {
        var result = await ContractHandler.UpdateContract(Model);
        if (result.Success)
        {
            Snackbar.Add("Contrato atualizado com sucesso.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add($"Erro ao atualizar: {result.Message}", Severity.Error);
        }
    }

    private async Task GerarDocumento()
    {
        if (Model.Status is ContractStatus.Ativo or ContractStatus.Cancelado)
        {
            Snackbar.Add("Contrato já foi finalizado. Não é possível gerar um novo documento.", Severity.Warning);
            return;
        }

        _gerando = true;
        try
        {
            Model.AcceptanceToken = Guid.NewGuid().ToString();
            Model.Status = ContractStatus.AguardandoAceitacao;

            var html = await RazorLight.CompileRenderAsync("ContractTemplate.cshtml", Model);
            Model.ContractDocumentHtml = html;

            var result = await ContractHandler.UpdateContract(Model);
            if (result.Success)
            {
                Snackbar.Add("Documento gerado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Erro ao salvar documento: {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao gerar documento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _gerando = false;
        }
    }
}
