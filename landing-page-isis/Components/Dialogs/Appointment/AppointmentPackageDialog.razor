@namespace landing_page_isis.Components.Dialogs.Appointment
@using landing_page_isis.core
@using landing_page_isis.core.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Model.Id == Guid.Empty ? Icons.Material.Filled.AddBox : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1"/>
            @(Model.Id == Guid.Empty ? "Novo Pacote" : "Editar Pacote")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="@_formValido">
            <MudGrid>
                @if (ShowPatientCoupleSelector)
                {
                    <MudItem xs="12">
                        <MudSelect T="string" Label="Vincular a" @bind-Value="_packageOwnerType"
                                   Required="true" Variant="Variant.Outlined">
                            <MudSelectItem Value="@("patient")">Paciente</MudSelectItem>
                            <MudSelectItem Value="@("couple")">Casal</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudNumericField T="int" Label="Quantidade de Consultas" Required="true" Min="1"
                                     @bind-Value="Model.TotalAppointments" Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField T="decimal" Label="Valor Total (R$)" Required="true" Min="0"
                                     @bind-Value="Model.Price" Variant="Variant.Outlined" Format="N2"/>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="PaymentMethod" Label="Forma de Pagamento" Required="true"
                               @bind-Value="Model.PaymentMethod" Variant="Variant.Outlined">
                        @foreach (PaymentMethod method in Enum.GetValues(typeof(PaymentMethod)))
                        {
                            <MudSelectItem Value="@method">@method.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudDivider DividerType="DividerType.Middle" Class="my-4"/>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Class="mr-2 mb-n1"/>
                        Dados do Pagador
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Nome do Pagador"
                                  @bind-Value="Model.PayerName" Variant="Variant.Outlined"
                                  MaxLength="150" Counter="150"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="CPF do Pagador"
                                  @bind-Value="Model.PayerCpf" Variant="Variant.Outlined"
                                  MaxLength="14" Counter="14"
                                  Mask="_cpfMask"/>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Color="Color.Error">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(!_formValido)" OnClick="Salvar">
            @(Model.Id == Guid.Empty ? "Criar Pacote" : "Salvar Alterações")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public AppointmentPackage Model { get; set; } = new AppointmentPackage() { TotalAppointments = 4, Price = 200, PaymentMethod = PaymentMethod.Pix };

    [Parameter]
    public bool ShowPatientCoupleSelector { get; set; }

    private bool _formValido;
    private PatternMask _cpfMask = new("000.000.000-00");
    private string _packageOwnerType = "patient";

    protected override void OnParametersSet()
    {
        if (Model.CoupleId.HasValue)
            _packageOwnerType = "couple";
    }

    private void Cancelar() => MudDialog.Cancel();

    private void Salvar()
    {
        if (Model.Id == Guid.Empty)
        {
            Model.RemainingAppointments = Model.TotalAppointments;
        }
        MudDialog.Close(DialogResult.Ok(Model));
    }
}
