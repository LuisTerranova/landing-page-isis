@namespace landing_page_isis.Components.Dialogs.Appointment
@using landing_page_isis.core.Models
@using landing_page_isis.core.Models.DTOs
@using landing_page_isis.core
@using landing_page_isis.core.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-3 mb-n1"/>
            @Titulo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="@_formValido">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="string" Label="Tipo" @bind-Value="_appointmentType"
                               Required="true" Variant="Variant.Outlined"
                               @bind-Value:after="OnTypeChanged">
                        <MudSelectItem Value="@("patient")">Paciente</MudSelectItem>
                        <MudSelectItem Value="@("couple")">Casal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    @if (_appointmentType == "patient")
                    {
                        <MudAutocomplete T="PatientListItemDto"
                                         Label="Paciente"
                                         @bind-Value="_selectedPatient"
                                         SearchFunc="@SearchPatient"
                                         ToStringFunc="@(p => p == null ? "" : p.Name)"
                                         Required="true"
                                         Variant="Variant.Outlined"
                                         ResetValueOnEmptyText="true"
                                         ShowProgressIndicator="true"
                                         ProgressIndicatorColor="Color.Primary"
                                         Placeholder="Comece a digitar o nome do paciente..."
                                         @bind-Value:after="OnPatientChanged"/>
                    }
                    else
                    {
                        <MudAutocomplete T="CoupleListItemDto"
                                         Label="Casal"
                                         @bind-Value="_selectedCouple"
                                         SearchFunc="@SearchCouple"
                                         ToStringFunc="@(c => c == null ? "" : c.Name)"
                                         Required="true"
                                         Variant="Variant.Outlined"
                                         ResetValueOnEmptyText="true"
                                         ShowProgressIndicator="true"
                                         ProgressIndicatorColor="Color.Primary"
                                         Placeholder="Comece a digitar o nome do casal..."
                                         @bind-Value:after="OnCoupleChanged"/>
                    }
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker Label="Data da Consulta"
                                   @bind-Date="_tempDate"
                                   Required="true"
                                   Variant="Variant.Outlined"
                                   Editable="true"/>
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker Label="Hora da Consulta"
                                   @bind-Time="_tempTime"
                                   Required="true"
                                   Variant="Variant.Outlined"
                                   Editable="true"/>
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField T="decimal" Label="Preço (R$)"
                                     @bind-Value="Model.Price"
                                     Format="N2"
                                     Variant="Variant.Outlined"
                                     Required="true"/>
                </MudItem>
                <MudItem xs="6">
                    <MudSelect T="AppointmentStatusEnum" Label="Status" @bind-Value="Model.AppointmentStatus" Required="true" Variant="Variant.Outlined">
                        @foreach (AppointmentStatusEnum status in Enum.GetValues(typeof(AppointmentStatusEnum)))
                        {
                            <MudSelectItem Value="@status">@status.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudDivider DividerType="DividerType.Middle" Class="my-4"/>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Class="mr-2 mb-n1"/>
                        Dados do Pagador
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Nome do Pagador"
                                  @bind-Value="Model.PayerName" Variant="Variant.Outlined"
                                  MaxLength="150" Counter="150"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="CPF do Pagador"
                                  @bind-Value="Model.PayerCpf" Variant="Variant.Outlined"
                                  MaxLength="14"
                                  Mask="_cpfMask"/>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Color="Color.Error">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(!_formValido)" OnClick="Salvar">
            Salvar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Inject] private IPatientHandler PatientHandler { get; set; } = null!;
    [Inject] private ICoupleHandler CoupleHandler { get; set; } = null!;

    [Parameter] public Appointment Model { get; set; } = new();
    [Parameter] public string Titulo { get; set; } = "Novo Agendamento";

    private bool _formValido;
    private PatternMask _cpfMask = new("000.000.000-00");
    private DateTime? _tempDate;
    private TimeSpan? _tempTime;
    private string _appointmentType = "patient";
    private PatientListItemDto? _selectedPatient;
    private CoupleListItemDto? _selectedCouple;

    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private IAppointmentPackageHandler PackageHandler { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        if (Model.PatientId.HasValue && Model.PatientId.Value != Guid.Empty)
        {
            var full = await PatientHandler.GetPatient(Model.PatientId.Value);
            if (full != null)
            {
                _selectedPatient = new PatientListItemDto(
                    full.Id, full.Name, full.Email, full.Phone, full.StateOfResidency
                );
                _appointmentType = "patient";
                await PrefillPayerFromPatient(full);
            }
        }
        else if (Model.CoupleId.HasValue)
        {
            var full = await CoupleHandler.GetCouple(Model.CoupleId.Value);
            if (full != null)
            {
                _selectedCouple = new CoupleListItemDto(
                    full.Id, full.Name, full.Patient1.Name, full.Patient2.Name,
                    full.Patient1.Phone, full.Patient1.Email
                );
                _appointmentType = "couple";
                if (!string.IsNullOrEmpty(full.PayerName))
                {
                    Model.PayerName ??= full.PayerName;
                    Model.PayerCpf ??= full.PayerCpf;
                }
            }
        }
    }

    private async Task PrefillPayerFromPatient(Patient patient)
    {
        if (!string.IsNullOrEmpty(patient.PayerName))
        {
            Model.PayerName ??= patient.PayerName;
            Model.PayerCpf ??= patient.PayerCpf;
        }
    }

    private async Task OnTypeChanged()
    {
        _selectedPatient = null;
        _selectedCouple = null;
        Model.PatientId = null;
        Model.CoupleId = null;
    }

    private async Task OnPatientChanged()
    {
        if (_selectedPatient != null)
        {
            var full = await PatientHandler.GetPatient(_selectedPatient.Id);
            if (full != null)
            {
                Model.PayerName = full.PayerName;
                Model.PayerCpf = full.PayerCpf;
            }
        }
    }

    private async Task OnCoupleChanged()
    {
        if (_selectedCouple != null)
        {
            var full = await CoupleHandler.GetCouple(_selectedCouple.Id);
            if (full != null)
            {
                Model.PayerName = full.PayerName;
                Model.PayerCpf = full.PayerCpf;
            }
        }
    }

    private async Task<IEnumerable<PatientListItemDto>> SearchPatient(string? value, CancellationToken ct)
    {
        var result = await PatientHandler.QueryPatients(value ?? "", 0, 10, ct);
        return result.Items;
    }

    private async Task<IEnumerable<CoupleListItemDto>> SearchCouple(string? value, CancellationToken ct)
    {
        var result = await CoupleHandler.QueryCouples(value ?? "", 0, 10, ct);
        return result.Items;
    }

    protected override void OnParametersSet()
    {
        if (Model.Id != Guid.Empty && Model.AppointmentDate != default)
        {
            var localTime = Model.AppointmentDate.ToPortoVelhoTime();
            _tempDate = localTime.Date;
            _tempTime = localTime.TimeOfDay;
        }
    }

    private void Cancelar() => MudDialog.Cancel();

    private async Task Salvar()
    {
        if (_appointmentType == "patient" && _selectedPatient != null)
        {
            var packagesResponse = await PackageHandler.GetPackagesByPatientId(0, 1, _selectedPatient.Id, CancellationToken.None);
            var hasActive = packagesResponse.Items.Any(p => p is { Status: PackageStatus.Ativo, RemainingAppointments: > 0 });

            if (!hasActive)
            {
                var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
                var dialog = await DialogService.ShowAsync<ConfirmScheduleDialog>("Atenção", options);
                var result = await dialog.Result;
                if (result == null || result.Canceled)
                    return;
            }
        }
        else if (_appointmentType == "couple" && _selectedCouple != null)
        {
            var packagesResponse = await PackageHandler.GetPackagesByCoupleId(0, 1, _selectedCouple.Id, CancellationToken.None);
            var hasActive = packagesResponse.Items.Any(p => p is { Status: PackageStatus.Ativo, RemainingAppointments: > 0 });

            if (!hasActive)
            {
                var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
                var dialog = await DialogService.ShowAsync<ConfirmScheduleDialog>("Atenção", options);
                var result = await dialog.Result;
                if (result == null || result.Canceled)
                    return;
            }
        }

        if (_tempDate.HasValue && _tempTime.HasValue)
        {
            var combinedDateTime = _tempDate.Value.Date + _tempTime.Value;
            Model.AppointmentDate = combinedDateTime.ToPortoVelhoDateTimeOffset();
        }

        if (_appointmentType == "patient")
        {
            Model.PatientId = _selectedPatient?.Id;
            Model.CoupleId = null;
        }
        else
        {
            Model.CoupleId = _selectedCouple?.Id;
            Model.PatientId = null;
        }

        MudDialog.Close(DialogResult.Ok(Model));
    }
}
