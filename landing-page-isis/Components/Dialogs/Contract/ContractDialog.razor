@namespace landing_page_isis.Components.Dialogs
@using landing_page_isis.core
@using landing_page_isis.core.Models
@using landing_page_isis.Extensions
@using RazorLight
@inject ISnackbar Snackbar
@inject IContractHandler ContractHandler
@inject RazorLightEngine RazorLight
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EditNote" Class="mr-3 mb-n1" />
            Editar Contrato
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="@_formValido">
            @if (Model.SecondaryPatient != null && !string.IsNullOrEmpty(Model.SecondaryPatient.Name))
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Favorite" Class="mr-2 mb-n1" />
                    Dados do Casal (somente leitura)
                </MudText>

                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Nome do Casal" Variant="Variant.Outlined"
                                      @bind-Value="Model.CoupleName" MaxLength="150"
                                      Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Parceiro 1" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Name" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="CPF Parceiro 1" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Cpf.FormatCpf()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Email" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Telefone" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Phone.FormatPhone()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Estado" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.State" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Nascimento" Variant="Variant.Outlined"
                                      Value="@(Model.PrimaryPatient.BirthDate?.ToString("dd/MM/yyyy") ?? "—")" Disabled="true" />
                    </MudItem>
                </MudGrid>

                <MudDivider DividerType="DividerType.Middle" Class="my-4" />

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Parceiro 2" Variant="Variant.Outlined"
                                      Value="@Model.SecondaryPatient.Name" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="CPF Parceiro 2" Variant="Variant.Outlined"
                                      Value="@Model.SecondaryPatient.Cpf.FormatCpf()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined"
                                      Value="@Model.SecondaryPatient.Email" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Telefone" Variant="Variant.Outlined"
                                      Value="@Model.SecondaryPatient.Phone.FormatPhone()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Estado" Variant="Variant.Outlined"
                                      Value="@Model.SecondaryPatient.State" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Nascimento" Variant="Variant.Outlined"
                                      Value="@(Model.SecondaryPatient.BirthDate?.ToString("dd/MM/yyyy") ?? "—")" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Pagador" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Name" Disabled="true" />
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-4">
                    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2 mb-n1" />
                    Dados do Paciente (somente leitura)
                </MudText>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Nome" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Name" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="CPF" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Cpf.FormatCpf()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Email" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Telefone" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.Phone.FormatPhone()" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Estado" Variant="Variant.Outlined"
                                      Value="@Model.PrimaryPatient.State" Disabled="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Nascimento" Variant="Variant.Outlined"
                                      Value="@(Model.PrimaryPatient.BirthDate?.ToString("dd/MM/yyyy") ?? "—")" Disabled="true" />
                    </MudItem>
                </MudGrid>
            }

            <MudDivider DividerType="DividerType.Middle" Class="my-6" />

            <MudText Typo="Typo.subtitle2" Color="Color.Secondary" Class="mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-2 mb-n1" />
                Detalhes do Contrato
            </MudText>

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?" Label="Valor por Sessão (R$)" Variant="Variant.Outlined"
                                     @bind-Value="Model.Price" Format="F2"
                                     Disabled="@(!_isEditing)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Status" Variant="Variant.Outlined"
                                  Value="@GetStatusLabel(Model.Status)" Disabled="true" />
                </MudItem>
            </MudGrid>

            <MudText Typo="Typo.subtitle2" Color="Color.Tertiary" Class="mt-6 mb-4">
                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Class="mr-2 mb-n1" />
                Pacote de Sessões
            </MudText>

            @if (_isEditing && Model.Price.HasValue && Model.InitialAppointments.HasValue && Model.PackagePrice.HasValue)
            {
                var desconto = (Model.Price.Value * Model.InitialAppointments.Value) - Model.PackagePrice.Value;
                <MudAlert Severity="Severity.Info" Class="mb-4" Style="font-size: 13px;">
                    <MudText Typo="Typo.body2">
                        <strong>@Model.InitialAppointments sessões</strong> avulsas: R$ @((Model.Price.Value * Model.InitialAppointments.Value).ToString("F2"))
                        &nbsp;→&nbsp; <strong>Pacote:</strong> R$ @Model.PackagePrice.Value.ToString("F2")
                        &nbsp;|&nbsp; <strong>Desconto:</strong> R$ @desconto.ToString("F2")
                    </MudText>
                </MudAlert>
            }

            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudNumericField T="int?" Label="Nº de Sessões" Variant="Variant.Outlined"
                                     @bind-Value="Model.InitialAppointments" Min="1" Max="99"
                                     HelperText="Quantidade de sessões no pacote"
                                     Disabled="@(!_isEditing)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudNumericField T="decimal?" Label="Preço do Pacote (R$)" Variant="Variant.Outlined"
                                     @bind-Value="Model.PackagePrice" Format="F2"
                                     HelperText="Valor total com desconto"
                                     Disabled="@(!_isEditing)" />
                </MudItem>
            </MudGrid>

        </MudForm>
    </DialogContent>
    <DialogActions>
        @if (!_isEditing)
        {
            <MudButton OnClick="Cancelar" Color="Color.Error">Fechar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" OnClick="ToggleEdit">
                Editar
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ToggleEdit">Cancelar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Save" OnClick="Salvar" Disabled="@(!_formValido)">
                Salvar
            </MudButton>
        }
        <span class="d-flex align-self-stretch mx-2" style="width: 1px; background: rgba(128,128,128,0.3);"></span>
        @if (Model.Status != ContractStatus.Cancelado)
        {
            <MudButton Color="Color.Warning" Variant="Variant.Outlined"
                       OnClick="CancelarContrato" Disabled="_cancelando">
                @if (_cancelando)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                Cancelar Contrato
            </MudButton>
        }
        <MudButton Color="Color.Tertiary" Variant="Variant.Outlined"
                   OnClick="GerarDocumento" Disabled="_gerando">
            @if (_gerando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Gerar Documento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Contract Model { get; set; } = new();

    private bool _formValido = true;
    private bool _gerando;
    private bool _cancelando;
    private bool _isEditing;

    private void Cancelar() => MudDialog.Cancel();

    private void ToggleEdit()
    {
        _isEditing = !_isEditing;
    }

    private static string GetStatusLabel(ContractStatus status) => status switch
    {
        ContractStatus.Rascunho => "Rascunho",
        ContractStatus.AguardandoAceitacao => "Aguardando Aceitação",
        ContractStatus.Ativo => "Ativo",
        ContractStatus.Cancelado => "Cancelado",
        _ => status.ToString(),
    };

    private async Task CancelarContrato()
    {
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            BackdropClick = false,
            CloseButton = true,
        };

        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirmar Cancelamento",
            $"Tem certeza que deseja cancelar o contrato de {(string.IsNullOrEmpty(Model.CoupleName) ? Model.PrimaryPatient.Name : Model.CoupleName)}?",
            yesText: "Sim, Cancelar",
            cancelText: "Voltar",
            options: options
        );

        if (confirm != true)
            return;

        _cancelando = true;
        try
        {
            Model.Status = ContractStatus.Cancelado;
            var result = await ContractHandler.UpdateContract(Model);
            if (result.Success)
            {
                Snackbar.Add("Contrato cancelado com sucesso.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Erro ao cancelar: {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao cancelar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _cancelando = false;
        }
    }

    private async Task Salvar()
    {
        var result = await ContractHandler.UpdateContract(Model);
        if (result.Success)
        {
            Snackbar.Add("Contrato atualizado com sucesso.", Severity.Success);
            _isEditing = false;
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            Snackbar.Add($"Erro ao atualizar: {result.Message}", Severity.Error);
        }
    }

    private async Task GerarDocumento()
    {
        if (Model.Status is ContractStatus.Ativo or ContractStatus.Cancelado)
        {
            Snackbar.Add("Contrato já foi finalizado. Não é possível gerar um novo documento.", Severity.Warning);
            return;
        }

        _gerando = true;
        try
        {
            if (Model.SecondaryPatient != null && !string.IsNullOrEmpty(Model.SecondaryPatient.Name) && string.IsNullOrWhiteSpace(Model.CoupleName))
            {
                var firstName1 = Model.PrimaryPatient.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).FirstOrDefault() ?? string.Empty;
                var firstName2 = Model.SecondaryPatient.Name?.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).FirstOrDefault() ?? string.Empty;
                Model.CoupleName = $"{firstName1} e {firstName2}";
            }

            Model.AcceptanceToken = Guid.NewGuid().ToString();
            Model.TokenGeneratedAt = DateTimeOffset.UtcNow;
            Model.Status = ContractStatus.AguardandoAceitacao;

            var html = await RazorLight.CompileRenderAsync("ContractTemplate.cshtml", Model);
            Model.ContractDocumentHtml = html;

            var result = await ContractHandler.UpdateContract(Model);
            if (result.Success)
            {
                Snackbar.Add("Documento gerado com sucesso!", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add($"Erro ao salvar documento: {result.Message}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro ao gerar documento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _gerando = false;
        }
    }
}
