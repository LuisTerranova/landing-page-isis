@namespace landing_page_isis.Components.Dialogs

<MudDialog>
    <DialogContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-0">
            <iframe srcdoc="@HtmlContent"
                    sandbox="allow-same-origin"
                    style="width: 100%; height: 70vh; border: none; border-radius: 12px;">
            </iframe>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Fechar" Color="Color.Primary" Variant="Variant.Filled">Fechar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public string HtmlContent { get; set; } = string.Empty;

    private void Fechar() => MudDialog.Close(DialogResult.Ok(true));
}
