@namespace landing_page_isis.Components.Dialogs.Patient
@using landing_page_isis.core.Models
@using PatientModel = landing_page_isis.core.Models.Patient

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3 mb-n1"/>
            @Titulo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @bind-IsValid="@_formValido">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Nome Completo" Required="true"
                                  @bind-Value="Model.Name" Variant="Variant.Outlined"
                                  MaxLength="150" Counter="150" Immediate="true"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="CPF" Required="true"
                                  @bind-Value="Model.Cpf" Variant="Variant.Outlined"
                                  MaxLength="11" Counter="11"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudDatePicker Label="Data de Nascimento"
                                   @bind-Date="_tempBirthDate"
                                   Required="true"
                                   Variant="Variant.Outlined"
                                   DateFormat="dd/MM/yyyy"
                                   Editable="true"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="E-mail"
                                  @bind-Value="Model.Email" Variant="Variant.Outlined"
                                  MaxLength="255" Counter="255" Immediate="true"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Telefone" Required="true"
                                  @bind-Value="Model.Phone" Variant="Variant.Outlined"
                                  MaxLength="11" Counter="11"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Estado"
                                  @bind-Value="Model.StateOfResidency" Variant="Variant.Outlined"
                                  MaxLength="2" HelperText="Sigla do estado"/>
                </MudItem>
                <MudItem xs="12">
                    <MudDivider DividerType="DividerType.Middle" Class="my-4"/>
                    <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Payments" Class="mr-2 mb-n1"/>
                        Dados do Pagador (se diferente do paciente)
                    </MudText>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="Nome do Pagador"
                                  @bind-Value="Model.PayerName" Variant="Variant.Outlined"
                                  MaxLength="150" Counter="150"/>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudTextField T="string" Label="CPF do Pagador"
                                  @bind-Value="Model.PayerCpf" Variant="Variant.Outlined"
                                  MaxLength="11" Counter="11"/>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Color="Color.Error">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(!_formValido)" OnClick="Salvar">
            Salvar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public PatientModel Model { get; set; } = new();
    [Parameter] public string Titulo { get; set; } = "Novo Paciente";

    private bool _formValido;
    private DateTime? _tempBirthDate;

    protected override void OnParametersSet()
    {
        _tempBirthDate = Model.BirthDate?.ToDateTime(TimeOnly.MinValue);
    }

    private void Cancelar() => MudDialog.Cancel();

    private void Salvar()
    {
        Model.BirthDate = _tempBirthDate.HasValue ? DateOnly.FromDateTime(_tempBirthDate.Value) : null;
        MudDialog.Close(DialogResult.Ok(Model));
    }

}