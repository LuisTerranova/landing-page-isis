@namespace landing_page_isis.Components.Dialogs.Patient

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EditNote" Class="mr-3" />
            Retificar Prontuário
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Em conformidade com a LGPD e regras do conselho, a nota anterior não será apagada. O texto inserido abaixo será adicionado ao final do prontuário com a data e hora da retificação.
        </MudAlert>
        <MudTextField @bind-Value="_rectificationNote"
                      Label="Retificação"
                      Lines="10"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Placeholder="Digite os novos dados para constar na retificação..."
                      Required="true"
                      RequiredError="O texto de retificação não pode estar em branco." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Error">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(string.IsNullOrWhiteSpace(_rectificationNote))">Gravar Retificação</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    private string _rectificationNote = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        MudDialog.Close(DialogResult.Ok(_rectificationNote));
    }
}
