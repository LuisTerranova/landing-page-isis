@namespace landing_page_isis.Components.Dialogs
@using landing_page_isis.core.Models
@using landing_page_isis.core

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@(Model.Id == Guid.Empty ? Icons.Material.Filled.AddBox : Icons.Material.Filled.Edit)" Class="mr-3 mb-n1"/>
            @(Model.Id == Guid.Empty ? "Novo Pacote" : "Editar Pacote")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_formValido">
            <MudGrid>
                <MudItem xs="12">
                    <MudNumericField T="int" Label="Quantidade de Consultas" Required="true" Min="1"
                                     @bind-Value="Model.TotalAppointments" Variant="Variant.Outlined"/>
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField T="decimal" Label="Valor Total (R$)" Required="true" Min="0"
                                     @bind-Value="Model.Price" Variant="Variant.Outlined" Format="N2"/>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="PaymentMethod" Label="Forma de Pagamento" Required="true"
                               @bind-Value="Model.PaymentMethod" Variant="Variant.Outlined">
                        @foreach (PaymentMethod method in Enum.GetValues(typeof(PaymentMethod)))
                        {
                            <MudSelectItem Value="@method">@method.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="@(!_formValido)" OnClick="Salvar">
            @(Model.Id == Guid.Empty ? "Criar Pacote" : "Salvar Alterações")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public AppointmentPackage Model { get; set; } = new AppointmentPackage() { TotalAppointments = 4, Price = 600, PaymentMethod = PaymentMethod.Pix };

    private MudForm _form = null!;
    private bool _formValido;

    private void Cancelar() => MudDialog.Cancel();

    private void Salvar()
    {
        // if it is a new package, initialize the remaining appointments
        if (Model.Id == Guid.Empty)
        {
            Model.RemainingAppointments = Model.TotalAppointments;
        }
        MudDialog.Close(DialogResult.Ok(Model));
    }
}
