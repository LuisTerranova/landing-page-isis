@using landing_page_isis.core.Models
@using landing_page_isis.Components.Dialogs
@rendermode InteractiveServer
@inject ILeadHandler LeadHandler
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<div id="contato" class="d-flex align-center justify-center"
     style="min-height: 100vh; width: 100%; background-color: #7E0F20; padding: 80px 0;">
    <MudContainer MaxWidth="MaxWidth.Large">
        <MudGrid Justify="Justify.Center" Class="d-flex align-items-center">
            <MudItem xs="12" md="5" Class="d-flex flex-column justify-center pe-md-12">
                <MudText Typo="Typo.h6" Style="letter-spacing: 3px; color: rgba(255,255,255,0.7); font-weight: 300;"
                         Class="mb-4">
                    VAMOS CONVERSAR?
                </MudText>
                <MudText Typo="Typo.h2" Style="color: white; line-height: 1.1;" Class="mb-8">
                    Dê o primeiro passo para sua transformação
                </MudText>
                <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.9); font-weight: 400; line-height: 1.6;">
                    Estou aqui para oferecer a escuta e a mediação que você busca. Entre em contato para agendar uma
                    consulta ou tirar dúvidas.
                </MudText>

            </MudItem>

            <MudItem xs="12" md="6" Class="mt-12 mt-md-0">
                <div class="pa-2">

                    <EditForm Model="@_lead" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator/>

                        <MudGrid Spacing="2" Class="mb-6">
                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Seu Nome" Variant="Variant.Outlined"
                                              @bind-Value="_lead.Name" For="@(() => _lead.Name)"
                                              Class="custom-contact-input" FullWidth="true"/>
                            </MudItem>

                            <MudItem xs="12" md="6">
                                <MudTextField T="string" Label="Celular (Whatsapp)" Variant="Variant.Outlined"
                                              @bind-Value="_lead.Phone" For="@(() => _lead.Phone)"
                                              Mask="@(new PatternMask("(00) 00000-0000"))"
                                              Class="custom-contact-input" FullWidth="true"/>
                            </MudItem>
                        </MudGrid>

                        <MudTextField T="string" Label="E-mail" Variant="Variant.Outlined"
                                      @bind-Value="_lead.Email" For="@(() => _lead.Email)"
                                      Class="custom-contact-input mb-6" FullWidth="true"/>

                        <MudTextField T="string" Label="Como posso te ajudar?" Variant="Variant.Outlined"
                                      @bind-Value="_lead.Intent" For="@(() => _lead.Intent)"
                                      Class="custom-contact-input mb-8" auto-grow="true" multiline="true" lines="3" MaxLines="15" FullWidth="true"/>

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                                   Style="background-color: #284B32; color: white; height: 60px; font-weight: 700; font-size: 1.1rem;"
                                   FullWidth="true"
                                   Class="rounded-lg shadow-2xl"
                                   Disabled="_processing">
                            @if (_processing)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                <MudText Class="ms-2">Enviando...</MudText>
                            }
                            else
                            {
                                <MudText>Enviar Mensagem</MudText>
                            }
                        </MudButton>
                    </EditForm>
                </div>
            </MudItem>

        </MudGrid>
    </MudContainer>
    <MudDialogProvider/>
</div>

@code {
    private Lead _lead = new();
    private bool _processing;

    private async Task HandleSubmit()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ConsentDialog>("", options);
        var dialogResult = await dialog.Result;

        if (dialogResult == null || dialogResult.Canceled || dialogResult.Data is not true)
        {
            return;
        }

        _lead.PolicySigned = true;
        _processing = true;
        try
        {
            var result = await LeadHandler.CreateLead(_lead);
            if (result.Success)
            {
                Snackbar.Add("Mensagem enviada com sucesso! Em breve entraremos em contato.", Severity.Success);
                _lead = new Lead();
            }
            else
            {
                Snackbar.Add($"Erro ao enviar mensagem: {result.Message}", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Ocorreu um erro inesperado ao enviar sua mensagem.", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

}