@using landing_page_isis.core.Models
@using landing_page_isis.Extensions
@model Contract
@{
    var separatorUri = AssetService.GetSeparatorDataUri();
}
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Contrato de Prestação de Serviços Psicológicos</title>
    <link rel="stylesheet" href="/css/templates/contract-template.css" />
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Contrato de Prestação de Serviços Psicológicos</h1>
        <div class="subtitle">Documento gerado em @DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(-3)).ToString("dd/MM/yyyy 'às' HH:mm") (Horário de Brasília)</div>
    </div>
    <div class="content">
        <h2>PARTES</h2>

        @if (Model.Couple != null)
        {
            <div class="party-box">
                <h3>CONTRATANTE — @Model.Couple.Name</h3>
                <p><strong>Parceiro 1:</strong> @Model.Couple.Patient1.Name — CPF: @Model.Couple.Patient1.Cpf.FormatCpf()</p>
                @if (!string.IsNullOrEmpty(Model.Couple.Patient1.Email))
                {
                    <p><strong>E-mail:</strong> @Model.Couple.Patient1.Email</p>
                }
                <p><strong>Telefone:</strong> @Model.Couple.Patient1.Phone.FormatPhone()</p>
                @if (!string.IsNullOrEmpty(Model.Couple.Patient1.StateOfResidency))
                {
                    <p><strong>Estado:</strong> @Model.Couple.Patient1.StateOfResidency</p>
                }
                @if (Model.Couple.Patient1.BirthDate.HasValue)
                {
                    <p><strong>Data de Nascimento:</strong> @Model.Couple.Patient1.BirthDate.Value.ToString("dd/MM/yyyy")</p>
                }
                <div style="margin-top: 12px; border-top: 1px dashed #284B32; padding-top: 12px;">
                    <p><strong>Parceiro 2:</strong> @Model.Couple.Patient2.Name — CPF: @Model.Couple.Patient2.Cpf.FormatCpf()</p>
                    @if (!string.IsNullOrEmpty(Model.Couple.Patient2.Email))
                    {
                        <p><strong>E-mail:</strong> @Model.Couple.Patient2.Email</p>
                    }
                    <p><strong>Telefone:</strong> @Model.Couple.Patient2.Phone.FormatPhone()</p>
                    @if (!string.IsNullOrEmpty(Model.Couple.Patient2.StateOfResidency))
                    {
                        <p><strong>Estado:</strong> @Model.Couple.Patient2.StateOfResidency</p>
                    }
                    @if (Model.Couple.Patient2.BirthDate.HasValue)
                    {
                        <p><strong>Data de Nascimento:</strong> @Model.Couple.Patient2.BirthDate.Value.ToString("dd/MM/yyyy")</p>
                    }
                </div>
                @if (!string.IsNullOrEmpty(Model.Couple.PayerName))
                {
                    <p style="margin-top: 12px;"><strong>Pagador:</strong> @Model.Couple.PayerName — CPF: @Model.Couple.PayerCpf.FormatCpf()</p>
                }
            </div>
        }
        else if (Model.SecondaryPatient != null && !string.IsNullOrEmpty(Model.SecondaryPatient.Name))
        {
            <div class="party-box">
                <h3>CONTRATANTE@(string.IsNullOrEmpty(Model.CoupleName) ? "" : " — " + Model.CoupleName)</h3>
                <p><strong>Parceiro 1:</strong> @Model.PrimaryPatient.Name — CPF: @Model.PrimaryPatient.Cpf.FormatCpf()</p>
                @if (!string.IsNullOrEmpty(Model.PrimaryPatient.Email))
                {
                    <p><strong>E-mail:</strong> @Model.PrimaryPatient.Email</p>
                }
                <p><strong>Telefone:</strong> @Model.PrimaryPatient.Phone.FormatPhone()</p>
                @if (!string.IsNullOrEmpty(Model.PrimaryPatient.State))
                {
                    <p><strong>Estado:</strong> @Model.PrimaryPatient.State</p>
                }
                @if (Model.PrimaryPatient.BirthDate.HasValue)
                {
                    <p><strong>Data de Nascimento:</strong> @Model.PrimaryPatient.BirthDate.Value.ToString("dd/MM/yyyy")</p>
                }

                <div style="margin-top: 12px; border-top: 1px dashed #284B32; padding-top: 12px;">
                    <p><strong>Parceiro 2:</strong> @Model.SecondaryPatient.Name — CPF: @Model.SecondaryPatient.Cpf.FormatCpf()</p>
                    @if (!string.IsNullOrEmpty(Model.SecondaryPatient.Email))
                    {
                        <p><strong>E-mail:</strong> @Model.SecondaryPatient.Email</p>
                    }
                    <p><strong>Telefone:</strong> @Model.SecondaryPatient.Phone.FormatPhone()</p>
                    @if (!string.IsNullOrEmpty(Model.SecondaryPatient.State))
                    {
                        <p><strong>Estado:</strong> @Model.SecondaryPatient.State</p>
                    }
                    @if (Model.SecondaryPatient.BirthDate.HasValue)
                    {
                        <p><strong>Data de Nascimento:</strong> @Model.SecondaryPatient.BirthDate.Value.ToString("dd/MM/yyyy")</p>
                    }
                </div>

                <p style="margin-top: 12px;"><strong>Pagador:</strong> @Model.PrimaryPatient.Name — CPF: @Model.PrimaryPatient.Cpf.FormatCpf()</p>
            </div>
        }
        else
        {
            <div class="party-box">
                <h3>CONTRATANTE</h3>
                <p><strong>Nome:</strong> @Model.PrimaryPatient.Name</p>
                <p><strong>CPF:</strong> @Model.PrimaryPatient.Cpf.FormatCpf()</p>
                @if (!string.IsNullOrEmpty(Model.PrimaryPatient.Email))
                {
                    <p><strong>E-mail:</strong> @Model.PrimaryPatient.Email</p>
                }
                <p><strong>Telefone:</strong> @Model.PrimaryPatient.Phone.FormatPhone()</p>
                @if (!string.IsNullOrEmpty(Model.PrimaryPatient.State))
                {
                    <p><strong>Estado:</strong> @Model.PrimaryPatient.State</p>
                }
                @if (Model.PrimaryPatient.BirthDate.HasValue)
                {
                    <p><strong>Data de Nascimento:</strong> @Model.PrimaryPatient.BirthDate.Value.ToString("dd/MM/yyyy")</p>
                }
            </div>
        }

        <div class="party-box">
            <h3>CONTRATADA</h3>
            <p><strong>Nome:</strong> Isis Vitória Alves da Silva Barbosa</p>
            <p><strong>Profissão:</strong> Psicóloga Clínica</p>
            <p><strong>Contato:</strong> (69) 99223-4931</p>
        </div>

        @if (Model.Price.HasValue)
        {
            <h2>VALOR DE REFERÊNCIA</h2>

            <table class="details-table">
                <tr>
                    <td>Valor por Sessão (Avulsa)</td>
                    <td>R$ @Model.Price.Value.ToString("F2")</td>
                </tr>
                @if (Model.InitialAppointments.HasValue && Model.PackagePrice.HasValue)
                {
                    <tr>
                        <td>Pacote de @Model.InitialAppointments Sessões</td>
                        <td>R$ @Model.PackagePrice.Value.ToString("F2")</td>
                    </tr>
                }
            </table>
        }

        <h2>CLÁUSULAS</h2>

        <div class="clause">
            <h3>CLÁUSULA 1ª — DO OBJETO</h3>
            <p>
                O presente contrato tem por objeto a prestação de serviços psicológicos pela CONTRATADA
                ao CONTRATANTE, compreendendo sessões de psicoterapia individual, a serem realizadas em
                consultório ou por meio digital (online), conforme previamente acordado entre as partes.
            </p>
            <p>
                Para as sessões online, é de responsabilidade do CONTRATANTE garantir conexão estável à internet,
                dispositivo adequado e estar em ambiente privado, silencioso e livre de interrupções que garantam o sigilo da sessão.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 2ª — DOS HONORÁRIOS</h3>
            <p>
                O valor de cada sessão avulsa é de <strong>R$ @Model.Price.GetValueOrDefault().ToString("F2")</strong>.
                @if (Model.InitialAppointments.HasValue && Model.PackagePrice.HasValue)
                {
                    <text>
                O CONTRATANTE poderá optar pelo pacote de <strong>@Model.InitialAppointments sessões</strong>
                pelo valor total de <strong>R$ @Model.PackagePrice.Value.ToString("F2")</strong>,
                conforme valores vigentes no momento de cada adesão.
                    </text>
                }
                else
                {
                    <text>
                O CONTRATANTE poderá optar, mês a mês, entre o pagamento por sessão avulsa ou pela adesão
                ao pacote mensal de sessões, conforme valores vigentes no momento de cada adesão.
                    </text>
                }
            </p>
            <p>
                O pagamento deverá ser efetuado antes do início de cada sessão, podendo ser realizado
                através de:
            </p>
            <p>
                Pix: (69) 99223-4931<br>
                Transferência bancária: Banco Inter (077) — Agência: 0001, Conta: 6559473-8
            </p>
            <p>
                Para pagamento via cartão de crédito, será acrescida a taxa da operadora,
                com o valor exato a ser simulado previamente.
            </p>
            <p>
                Os honorários poderão sofrer reajuste a cada 6 (seis) meses a critério da CONTRATADA,
                mediante comunicação prévia de 30 (trinta) dias ao CONTRATANTE, facultando a este a 
                rescisão do contrato caso não concorde com o novo valor.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 3ª — DO CANCELAMENTO E ATRASOS</h3>
            <p>
                As sessões terão duração aproximada de 50 (cinquenta) minutos, com frequência
                semanal acordada entre as partes. A tolerância máxima de atraso é de 20 (vinte)
                minutos; após esse prazo, a sessão será reagendada, caso haja disponibilidade do
                contratado, caso contrário, será considerado falta.
            </p>
            <p>
                Em caso de atraso por parte do CONTRATANTE dentro da tolerância de 20 minutos, a
                sessão será realizada no tempo restante do horário agendado, terminando pontualmente
                no horário previsto para não prejudicar os atendimentos subsequentes.
            </p>
            <p>
                O cancelamento ou reagendamento deverá ser comunicado com, no mínimo, 24 (vinte e
                quatro) horas de antecedência. O não comparecimento sem o devido aviso prévio
                implicará na cobrança integral da sessão, inclusive para sessões integrantes de
                pacote mensal.
            </p>
            <p>
                A CONTRATADA compromete-se com a pontualidade e assiduidade. Em caso de eventual
                ausência ou emergência, o CONTRATANTE será comunicado com a devida antecedência;
                não sendo possível o aviso prévio, a sessão será compensada em data oportuna.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 4ª — DO SIGILO PROFISSIONAL</h3>
            <p>
                A CONTRATADA obriga-se a manter absoluto sigilo sobre todas as informações, dados
                e conteúdo das sessões, em conformidade com o Código de Ética Profissional do
                Psicólogo (Resolução CFP nº 010/2005). As informações somente serão reveladas a
                terceiros mediante autorização expressa e por escrito do CONTRATANTE, ressalvadas
                as exceções legais previstas no Art. 9º e Art. 10º do referido código, como
                situações de risco à vida, comunicação de crime ou determinação judicial. O
                registro das sessões será armazenado em prontuário eletrônico seguro, conforme
                a Resolução CFP nº 001/2009.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 5ª — DA COMUNICAÇÃO E EMERGÊNCIAS</h3>
            <p>
                A comunicação entre as partes dar-se-á preferencialmente durante as sessões. Para
                assuntos administrativos, o CONTRATANTE poderá entrar em contato pelo telefone
                (69) 99223-4931 (WhatsApp) de segunda a sexta-feira, em horário comercial. A CONTRATADA retornará assim que possível, no prazo máximo de 24 (vinte e quatro) horas úteis.
            </p>
            <p>
                Em situações de crise severa, urgência ou emergência médica/psiquiátrica, o CONTRATANTE deve procurar atendimento imediato no pronto-socorro mais próximo ou acionar o CVV (188) / SAMU (192), não sendo o WhatsApp um canal de atendimento de emergência.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 6ª — DA VIGÊNCIA E RESCISÃO</h3>
            <p>
                O presente contrato entra em vigor a partir da data de sua aceitação, vigorando
                por prazo indeterminado enquanto durar o processo terapêutico. Ambas as partes
                poderão rescindir o contrato a qualquer momento, mediante comunicação expressa.
                Recomenda-se a realização de uma sessão de encerramento para avaliação do processo
                e orientações finais. Em caso de desistência do pacote mensal após o pagamento,
                os valores não serão reembolsados, salvo acordo expresso entre as partes.
            </p>
            <p>
                A CONTRATADA reserva-se o direito de rescindir o atendimento e realizar o devido encaminhamento do paciente nos casos de: desrespeito, falta recorrente não justificada, ou quando identificar razões éticas e técnicas que exijam o encerramento da intervenção, garantindo o devido alinhamento na sessão de encerramento.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 7ª — DA PROTEÇÃO DE DADOS (LGPD)</h3>
            <p>
                A CONTRATADA compromete-se a tratar os dados pessoais do CONTRATANTE em conformidade
                com a Lei Geral de Proteção de Dados Pessoais (Lei nº 13.709/2018), utilizando-os
                exclusivamente para os fins do presente contrato e mantendo-os armazenados de forma
                segura. O CONTRATANTE declara ter lido e concordado com a Política de Privacidade
                disponível no site da CONTRATADA. Os dados sensíveis relativos à saúde serão
                tratados com as salvaguardas adicionais previstas no Art. 11 da LGPD.
            </p>
        </div>

        <div class="clause">
            <h3>CLÁUSULA 8ª — DAS DISPOSIÇÕES GERAIS</h3>
            <p>
                Este contrato representa o acordo integral entre as partes, selando o compromisso
                terapêutico. Quaisquer alterações nas condições aqui pactuadas deverão ser
                formalizadas mediante aditivo contratual. Fica eleito o foro da comarca de
                Porto Velho/RO para dirimir quaisquer questões oriundas deste contrato.
            </p>
        </div>

        <div class="signature-section">
            <p>Porto Velho/RO, @DateTimeOffset.UtcNow.ToOffset(TimeSpan.FromHours(-3)).ToString("dd 'de' MMMM 'de' yyyy")</p>

            @if (Model.AcceptedAt.HasValue)
            {
                <div class="electronic-stamp">
                    <strong>✓ ASSINADO ELETRONICAMENTE</strong><br>
                    @Model.AcceptedAt.Value.ToOffset(TimeSpan.FromHours(-3)).ToString("dd/MM/yyyy 'às' HH:mm:ss") (Horário de Brasília)
                </div>
            }

            @if (Model.Couple != null)
            {
                <p><strong>@Model.Couple.Name</strong></p>
                <p>CONTRATANTE (representado por @Model.Couple.PayerName)</p>
            }
            else if (Model.SecondaryPatient != null && !string.IsNullOrEmpty(Model.SecondaryPatient.Name))
            {
                var coupleDisplay = !string.IsNullOrEmpty(Model.CoupleName) ? Model.CoupleName : $"{Model.PrimaryPatient.Name} & {Model.SecondaryPatient.Name}";
                <p><strong>@coupleDisplay</strong></p>
                <p>CONTRATANTE (representado por @Model.PrimaryPatient.Name)</p>
            }
            else
            {
                <p><strong>@Model.PrimaryPatient.Name</strong></p>
                <p>CONTRATANTE</p>
            }

            <div class="signature-line" style="margin-top: 50px;"></div>
            <p><strong>Isis Vitória Alves da Silva Barbosa</strong></p>
            <p>CONTRATADA</p>
        </div>
    </div>
    <div class="footer">
        <img src="@separatorUri" alt="" class="footer-separator" />
        <p>
            <strong>Isis Vitória Alves da Silva Barbosa</strong> — Psicóloga Clínica<br>
            Este documento foi gerado eletronicamente e é válido como contrato de prestação de serviços.
        </p>
    </div>
</div>
</body>
</html>
