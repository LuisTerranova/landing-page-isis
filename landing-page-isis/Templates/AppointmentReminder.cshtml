@using landing_page_isis.core.Models
@model Appointment

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Lembrete de Sessão</title>
    <link rel="stylesheet" href="/css/templates/appointment-reminder.css" />
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Lembrete de Próxima Sessão</h1>
    </div>
    <div class="content">
        <p>Olá, <strong>@(Model.Patient?.Name ?? "Paciente")</strong>,</p>
        <p>Este é um lembrete para nossa sessão agendada para amanhã. Estou passando para confirmar o seu horário:</p>

        <div class="appointment-info">
            @{
                var brTimeZone = TimeZoneInfo.FindSystemTimeZoneById("America/Sao_Paulo");
                var brDateTime = TimeZoneInfo.ConvertTime(Model.AppointmentDate, brTimeZone);
            }
            <div class="date-time">
                @brDateTime.ToString("dd/MM/yyyy 'às' HH:mm")
            </div>
            <p>Horário de Brasília</p>
        </div>

        <p>Se precisar reagendar ou cancelar, por favor, me avise com antecedência (preferencialmente em até 24h).</p>

        <p>
            Estou ansiosa para nosso próximo encontro.<br>
            <strong>Isis Vitória</strong><br>
            Psicóloga Clínica
        </p>
    </div>
    <div class="footer">
        <p>
            Este e-mail é um serviço automático de lembretes.<br>
            &copy; @DateTime.Now.Year Isis Vitória - Todos os direitos reservados.
        </p>
    </div>
</div>
</body>
</html>
